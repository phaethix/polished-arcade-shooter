{
  "name": "polished-arcade-shooter",
  "private": true,
  "version": "0.10.0",
  "description": "Sky Blaster — browser vertical shoot-'em-up with four modes, meta progression, and procedural audio. React, TypeScript, Canvas.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phaethix/polished-arcade-shooter.git"
  },
  "bugs": {
    "url": "https://github.com/phaethix/polished-arcade-shooter/issues"
  },
  "homepage": "https://phaethix.github.io/polished-arcade-shooter/",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:pages": "vite build --mode pages",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && npm run typecheck:party",
    "typecheck:party": "tsc --noEmit -p tsconfig.party.json",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "commitlint": "commitlint --edit",
    "prepare": "husky",
    "party:dev": "wrangler dev",
    "party:deploy": "wrangler deploy"
  },
  "dependencies": {
    "partyserver": "^0.5.8",
    "partysocket": "^1.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260714.1",
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "4.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "9.1.7",
    "prettier": "^3.9.5",
    "tailwindcss": "4.3.2",
    "typescript": "7.0.2",
    "typescript-eslint": "^8.64.0",
    "vite": "8.1.4",
    "vite-plugin-singlefile": "2.3.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}

{
  "name": "polished-arcade-shooter",
  "private": true,
  "version": "0.1.0",
  "description": "Sky Blaster — browser vertical shoot-'em-up with four modes, meta progression, and procedural audio. React, TypeScript, Canvas.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phaethix/polished-arcade-shooter.git"
  },
  "bugs": {
    "url": "https://github.com/phaethix/polished-arcade-shooter/issues"
  },
  "homepage": "https://phaethix.github.io/polished-arcade-shooter/",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:pages": "vite build --mode pages",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "commitlint": "commitlint --edit",
    "prepare": "husky"
  },
  "dependencies": {
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "4.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "9.1.7",
    "prettier": "^3.9.5",
    "tailwindcss": "4.3.2",
    "typescript": "7.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "8.1.4",
    "vite-plugin-singlefile": "2.3.3",
    "vitest": "^4.1.10"
  }
}

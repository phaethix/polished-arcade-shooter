{
  "name": "polished-arcade-shooter",
  "private": true,
  "version": "0.1.0",
  "description": "Sky Blaster — browser vertical shoot-'em-up with four modes, meta progression, and procedural audio. React, TypeScript, Canvas.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phaethix/polished-arcade-shooter.git"
  },
  "bugs": {
    "url": "https://github.com/phaethix/polished-arcade-shooter/issues"
  },
  "homepage": "https://phaethix.github.io/polished-arcade-shooter/",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:pages": "vite build --mode pages",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "commitlint": "commitlint --edit",
    "prepare": "husky",
    "party:dev": "partykit dev",
    "party:deploy": "partykit deploy"
  },
  "dependencies": {
    "partysocket": "^1.3.0",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@commitlint/cli": "19.8.1",
    "@commitlint/config-conventional": "19.8.1",
    "@eslint/js": "^9.32.0",
    "@tailwindcss/vite": "4.1.17",
    "@types/node": "22.19.17",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "9.1.7",
    "partykit": "^0.0.115",
    "prettier": "^3.6.2",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "7.3.2",
    "vite-plugin-singlefile": "2.3.0",
    "vitest": "^3.2.4"
  }
}

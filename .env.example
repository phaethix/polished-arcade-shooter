# Co-op server host (no protocol). Points the browser WebSocket client at the room server.
# Dev (wrangler dev): localhost:8787
# Prod: the *.workers.dev URL from `npm run party:deploy`
VITE_PARTYKIT_HOST=localhost:8787

# (Optional, server-side) Client origin allowed to open co-op WebSockets.
# Set on deploy so the worker sends the right CORS header for the static game host.
#   npx wrangler deploy --var PARTYKIT_HOST:https://phaethix.github.io
